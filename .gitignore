/target
**/*.rs.bk
Cargo.lock.bak

# Parity test artifacts: generated by scripts/ at runtime.
# We keep per-run report.txt files (small, useful for PR descriptions)
# but exclude the multi-hundred-megabyte upstream build tree and the
# generated BAM/VCF fixtures.
/parity/upstream/
# Fixture data — can appear at top level (older synthetic fixtures) or in
# per-dataset subdirs (e.g. parity/fixtures/hg002_mt/).
/parity/fixtures/**/*.bam
/parity/fixtures/**/*.bam.bai
/parity/fixtures/**/*.fa
/parity/fixtures/**/*.fa.fai
/parity/fixtures/**/*.fai
/parity/fixtures/**/*.sam
/parity/fixtures/**/*.vcf
/parity/fixtures/**/*.vcf.gz
/parity/fixtures/**/*.vcf.gz.tbi
# Comparison outputs — only report.txt is committed.
/parity/compare/**/*.vcf
/parity/compare/**/*.vcf.gz
/parity/compare/**/*.vcf.gz.tbi
/parity/compare/**/*.reheadered.vcf
/parity/compare/**/*.sorted.vcf
/parity/compare/**/*.rh.vcf
/parity/compare/**/*.time.log
/parity/compare/**/isec_*/
/parity/compare/**/isec/
